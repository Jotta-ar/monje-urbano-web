# Copiá este archivo a ".env.local" (nunca lo subas a git) y completá los valores
# reales una vez que tengas los proyectos/cuentas creados.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Único email autorizado como administrador/a. requireAdmin() (src/lib/admin-auth.ts)
# lo compara contra el email del usuario autenticado de Supabase antes de dejarlo
# usar /api/admin/*. Sin esta variable, TODO acceso admin queda denegado (fail-closed).
ADMIN_EMAIL=

# Mercado Pago (Credenciales -> Producción / Prueba)
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# PayPal (developer.paypal.com -> Apps & Credentials). Cuenta Business
# requerida para poder cobrar vía API — una cuenta personal no alcanza.
# PAYPAL_MODE=sandbox mientras se prueba, =live para cobrar de verdad.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Envío de emails transaccionales (ej. Resend: https://resend.com)
RESEND_API_KEY=
NOTIFY_EMAIL=pedidos@monjeurbanolibre.com

# URL pública del sitio (para armar los links de regalo /completar/[token])
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Panel de Crecimiento — métrica automática de YouTube (src/lib/youtube.ts).
# YOUTUBE_API_KEY: gratis, la creás vos en https://console.cloud.google.com
#   -> crear proyecto -> "APIs & Services" -> Library -> habilitar "YouTube Data API v3"
#   -> Credentials -> Create Credentials -> API key. No hace falta OAuth ni
#   tocar la cuenta del canal, es una API key de solo lectura de datos públicos.
# YOUTUBE_CHANNEL_ID: se ve en YouTube Studio -> Configuración -> Canal ->
#   Información básica del canal (empieza con "UC...").
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Secreto compartido para /api/cron/*. Vercel lo manda solo como
# "Authorization: Bearer <CRON_SECRET>" en cada llamada programada (ver
# vercel.json) si esta misma variable está seteada en el proyecto de Vercel.
# Generá cualquier string largo random, no tiene que ser memorizable.
CRON_SECRET=
